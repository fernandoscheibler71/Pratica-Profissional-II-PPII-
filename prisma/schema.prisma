generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")

  }

model User {
  id    Int     @id @default(autoincrement())
  name  String
  email String @unique
  senha String 

  members members_community[]
  messages Messages[]

  
}


model Community {
  id Int @id @default(autoincrement())
  nameCommunity String @unique
  profileImage   String @default("url")
  
  members members_community[]
  subCommunitys SubCommunity[]

}

model SubCommunity {
  SubCommunityId Int @id @default(autoincrement())
  communityId Int  
  name String

  community Community @relation(fields: [communityId], references: [id])

  chat Chat[]


}

model members_community {
  userId      Int
  communityId Int

  user User @relation(fields: [userId], references: [id])
  community Community @relation(fields: [communityId], references: [id])

  @@id([userId, communityId])

}

model Chat {
  id Int @id @default(autoincrement())
  subCommunityId Int 

  subCommunity SubCommunity @relation(fields: [subCommunityId], references: [SubCommunityId])

  messages Messages[]
  
}

model Messages {
  id Int @id @default(autoincrement())
  userId Int
  contet String

  user User @relation(fields: [userId], references: [id])
  chatId Int
  chat Chat @relation(fields: [chatId], references: [id])
  
}



